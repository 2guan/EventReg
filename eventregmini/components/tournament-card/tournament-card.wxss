/**
 * 活动卡片组件样式
 * 与网页版 TournamentCard.tsx 样式完全一致
 */

.tournament-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  border: 2rpx solid #f3f4f6;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
  transition: box-shadow 0.2s;
}

.tournament-card:active {
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 暗色模式 */
.tournament-card.dark {
  background-color: #1f2937;
  border-color: #374151;
}

/* 图片容器 */
.card-image-container {
  position: relative;
  width: 100%;
  height: 140rpx;
}

.card-image {
  width: 100%;
  height: 100%;
}

/* 状态标签 */
.status-tag {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  opacity: 0.9; /* 90% 不透明度 */
}

/* 预报名 - 蓝色 */
.status-pre-registration {
  background-color: #dbeafe;
  color: #1e40af;
}

/* 报名中 - 绿色 (带脉冲动效) */
.status-registration {
  background-color: #dcfce7;
  color: #166534;
  animation: status-pulse 2s infinite ease-in-out;
}

@keyframes status-pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

/* 可候补 - 黄色 */
.status-waiting-list {
  background-color: #fef9c3;
  color: #854d0e;
}

/* 已满员 - 灰色 */
.status-full {
  background-color: #f3f4f6;
  color: #1f2937;
}

/* 待结算 - 橙色 */
.status-finished-pending {
  background-color: #ffedd5;
  color: #9a3412;
}

/* 已结束 - 靛蓝 */
.status-finished-completed {
  background-color: #e0e7ff;
  color: #3730a3;
}

/* 已取消 - 红色 */
.status-cancelled {
  background-color: #fee2e2;
  color: #991b1b;
}



/* 已报名标签容器 */
.enrolled-tags-container {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-start;
}

/* 已报名标签 */
.enrolled-tag {
  background-color: #16a34a; /* 统一使用深一点的绿色 */
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  opacity: 0.9; /* 90% 不透明度 */
}

.enrolled-tag.mini {
  padding: 6rpx 16rpx; /* 稍微增加一点内边距 */
  font-size: 22rpx; /* 调大一点点 (之前是20rpx) */
}

.enrolled-tag.proxy {
  background-color: #16a34a; 
}

.enrolled-tag .icon-check {
  margin-right: 6rpx;
  font-size: 20rpx;
}

.enrolled-tag.mini .icon-check {
  font-size: 20rpx; /* 同步调大图标 */
}


/* 热门标签 */
.popular-tag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background-color: #ef4444;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 9999rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  opacity: 0.9; /* 90% 不透明度 */
}

/* 卡片内容 */
.card-content {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
}

.card-info {
  flex: 1;
  padding-right: 16rpx;
}

/* 标题 */
.card-title {
  font-weight: 700;
  font-size: 36rpx;
  line-height: 1.25;
  margin-bottom: 16rpx;
  color: #111827;
}

.dark .card-title {
  color: #ffffff;
}

/* 元信息 */
.card-meta {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.dark .card-meta {
  color: #9ca3af;
}

.card-meta .icon-calendar,
.card-meta .icon-location {
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* 分享按钮 */
.share-btn {
  display: flex;
  align-items: center;
  color: #9ca3af;
  font-size: 28rpx;
  margin-top: 8rpx;
  padding: 8rpx 0;
}

.share-btn:active {
  color: #6b7280;
}

.share-btn .icon-share {
  margin-right: 8rpx;
}

/* 原生分享按钮(button类型) */
.share-btn-native {
  display: inline-flex !important;
  align-items: center;
  color: #9ca3af;
  font-size: 28rpx;
  margin-top: 8rpx;
  margin-left: -8rpx;
  margin-right: auto;
  padding: 4rpx 8rpx !important;
  background-color: transparent !important;
  border: none !important;
  line-height: 1.5;
  width: auto !important;
  min-width: 0 !important;
  max-width: fit-content !important;
  min-height: auto !important;
}

.share-btn-native::after {
  border: none;
}

.share-btn-native:active {
  color: #6b7280;
  background-color: rgba(0, 0, 0, 0.05);
}

.share-btn-native .icon-share {
  margin-right: 8rpx;
}

/* 统计信息 */
.card-stats {
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
}

.stat-box {
  padding: 16rpx 0; /* 仅保留垂直边距，水平靠宽度撑开并居中 */
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 16rpx;
  width: 160rpx; /* 改为固定宽度 */
}

.stat-box:last-child {
  margin-bottom: 0;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

/* 蓝色统计框 */
.stat-blue {
  background-color: #dbeafe;
}

.stat-blue .stat-label {
  color: #2563eb;
}

.stat-blue .stat-value {
  color: #1e40af;
}

.dark .stat-blue {
  background-color: rgba(30, 58, 138, 0.5);
}

.dark .stat-blue .stat-label {
  color: #93c5fd;
}

.dark .stat-blue .stat-value {
  color: #bfdbfe;
}

/* 绿色统计框 */
.stat-green {
  background-color: #dcfce7;
}

.stat-green .stat-label {
  color: #16a34a;
}

.stat-green .stat-value {
  color: #166534;
}

.dark .stat-green {
  background-color: rgba(20, 83, 45, 0.5);
}

.dark .stat-green .stat-label {
  color: #86efac;
}

.dark .stat-green .stat-value {
  color: #bbf7d0;
}

/* 黄色统计框 */
.stat-yellow {
  background-color: #fef9c3;
}

.stat-yellow .stat-label {
  color: #ca8a04;
}

.stat-yellow .stat-value {
  color: #854d0e;
}

.dark .stat-yellow {
  background-color: rgba(113, 63, 18, 0.5);
}

.dark .stat-yellow .stat-label {
  color: #fde047;
}

.dark .stat-yellow .stat-value {
  color: #fef08a;
}

/* 紫色统计框 */
.stat-purple {
  background-color: #f3e8ff;
}

.stat-purple .stat-label {
  color: #9333ea;
}

.stat-purple .stat-value {
  color: #6b21a8;
}

.dark .stat-purple {
  background-color: rgba(88, 28, 135, 0.5);
}

.dark .stat-purple .stat-label {
  color: #d8b4fe;
}

.dark .stat-purple .stat-value {
  color: #e9d5ff;
}

/* 分享模态框 */
.share-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.share-modal {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
}

.dark .share-modal {
  background-color: #1f2937;
}

.share-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.share-modal-title {
  font-size: 36rpx;
  font-weight: 700;
}

.share-modal-close {
  font-size: 48rpx;
  color: #9ca3af;
  padding: 16rpx;
}

.share-modal-body {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.share-btn-item {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(to right, #ef4444, #fb923c);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.share-btn-item::after {
  border: none;
}
