/**
 * 首页样式
 * 与网页版 Home.tsx 样式完全一致
 */

.page {
  min-height: 100vh;
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
  background-color: #f9fafb;
}

.page.dark {
  background-color: #111827;
}

/* 顶部导航栏 */
.header {
  position: sticky;
  top: 0;
  z-index: 30;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.dark .header {
  background-color: #1f2937;
}

.header-left {
  display: flex;
  align-items: center;
}

.app-logo {
  font-size: 48rpx;
  margin-right: 12rpx;
}

.app-name {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(to right, #ef4444, #fb923c);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.theme-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.theme-btn:active {
  background-color: #f3f4f6;
}

.dark .theme-btn:active {
  background-color: #374151;
}

.theme-btn text {
  font-size: 40rpx;
}

.admin-btn {
  padding: 10rpx 20rpx;
  background-color: #ef4444;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 9999rpx;
}

.admin-btn:active {
  background-color: #dc2626;
}

.logout-btn {
  padding: 10rpx 20rpx;
  background-color: #f3f4f6;
  color: #1f2937;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 9999rpx;
}

.dark .logout-btn {
  background-color: #374151;
  color: #ffffff;
}

.logout-btn:active {
  background-color: #e5e7eb;
}

.dark .logout-btn:active {
  background-color: #4b5563;
}

.login-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(to right, #ef4444, #fb923c);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 9999rpx;
}

.login-btn:active {
  opacity: 0.9;
}

/* 主内容区 */
.main-content {
  height: calc(100vh - 120rpx);
  padding: 24rpx 32rpx;
  padding-bottom: 160rpx;
}

/* 欢迎横幅 */
.welcome-banner {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 48rpx;
}

.banner-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, #ef4444, #fb923c);
}

.banner-circle-1 {
  position: absolute;
  right: 0;
  top: -48rpx;
  width: 128rpx;
  height: 128rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.banner-circle-2 {
  position: absolute;
  right: 64rpx;
  bottom: -64rpx;
  width: 96rpx;
  height: 96rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.banner-content {
  position: relative;
  z-index: 1;
  padding: 48rpx;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
  margin-right: 32rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.points-badge {
  display: inline-block;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 24rpx;
  border-radius: 9999rpx;
}

.points-badge text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
}

.register-prompt {
  margin-top: 16rpx;
  padding: 16rpx 32rpx;
  background-color: transparent;
  border: 2rpx solid #ffffff;
  border-radius: 9999rpx;
  display: inline-block;
}

.register-prompt text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.register-prompt:active {
  background-color: rgba(255, 255, 255, 0.1);
}

/* 区域样式 */
.section {
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .section-title {
  color: #ffffff;
}

/* 活动列表 */
.tournament-list {
  /* 列表容器 */
}

/* 底部安全区域 */
.bottom-safe-area {
  height: 180rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #ef4444;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
