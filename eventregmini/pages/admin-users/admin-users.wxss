/**
 * 用户管理页面样式
 * 与网页版 AdminUsers.tsx 样式完全一致
 */

.page {
  min-height: 100vh;
  background-color: #f9fafb;
  display: flex;
  flex-direction: column;
}

.page.dark {
  background-color: #111827;
}

/* 顶部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.dark .header {
  background-color: #1f2937;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #1f2937;
}

.dark .back-btn {
  color: #ffffff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .header-title {
  color: #ffffff;
}

.settings-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #f3f4f6;
  border-radius: 12rpx;
}

.dark .settings-btn {
  background-color: #374151;
}

.settings-btn text:first-child {
  font-size: 28rpx;
}

.settings-text {
  font-size: 24rpx;
  color: #1f2937;
}

.dark .settings-text {
  color: #ffffff;
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding: 24rpx;
}

/* 搜索框 */
.search-box {
  position: relative;
  margin-bottom: 24rpx;
}

.search-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  z-index: 1;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx 0 72rpx;
  background-color: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
  line-height: 80rpx;
}

.dark .search-input {
  background-color: #1f2937;
  border-color: #374151;
  color: #ffffff;
}

.search-placeholder {
  color: #9ca3af;
}

/* 用户列表 */
.user-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.user-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #f3f4f6;
}

.dark .user-card {
  background-color: #1f2937;
  border-color: #374151;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.user-profile {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #e5e7eb;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.dark .user-name {
  color: #ffffff;
}

.user-username {
  font-size: 24rpx;
  color: #6b7280;
}

.dark .user-username {
  color: #9ca3af;
}

.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.points-badge {
  padding: 6rpx 14rpx;
  background-color: #fef3c7;
  color: #d97706;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

.dark .points-badge {
  background-color: rgba(251, 191, 36, 0.2);
  color: #fcd34d;
}

.role-tag {
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.role-tag.admin {
  background-color: #f3e8ff;
  color: #7c3aed;
}

.dark .role-tag.admin {
  background-color: rgba(124, 58, 237, 0.2);
  color: #c4b5fd;
}

.role-tag.pending {
  background-color: #ffedd5;
  color: #ea580c;
}

.dark .role-tag.pending {
  background-color: rgba(234, 88, 12, 0.2);
  color: #fdba74;
}

.role-tag.user {
  background-color: #dbeafe;
  color: #2563eb;
}

.dark .role-tag.user {
  background-color: rgba(37, 99, 235, 0.2);
  color: #93c5fd;
}

/* 积分显示 */
.points-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #f9fafb;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.dark .points-row {
  background-color: #374151;
}

.points-label {
  font-size: 26rpx;
  color: #6b7280;
}

.dark .points-label {
  color: #9ca3af;
}

.points-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #f97316;
  font-family: monospace;
}

/* 操作按钮网格 */
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background-color: #f3f4f6;
  border-radius: 12rpx;
}

.dark .action-item {
  background-color: #374151;
}

.action-item.add {
  background-color: #dcfce7;
}

.dark .action-item.add {
  background-color: rgba(34, 197, 94, 0.2);
}

.action-item.deduct {
  background-color: #fee2e2;
}

.dark .action-item.deduct {
  background-color: rgba(239, 68, 68, 0.2);
}

.action-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 20rpx;
  color: #6b7280;
}

.dark .action-text {
  color: #9ca3af;
}

.action-item.add .action-text {
  color: #16a34a;
}

.dark .action-item.add .action-text {
  color: #86efac;
}

.action-item.deduct .action-text {
  color: #dc2626;
}

.dark .action-item.deduct .action-text {
  color: #fca5a5;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 32rpx;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.dark .empty-title {
  color: #ffffff;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
}

.dark .empty-desc {
  color: #9ca3af;
}

/* 加载状态 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #ef4444;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  z-index: 100;
}

.modal {
  width: 100%;
  max-width: 640rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  max-height: 90vh;
}

.dark .modal {
  background-color: #1f2937;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.dark .modal-header {
  border-bottom-color: #374151;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .modal-title {
  color: #ffffff;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close text {
  font-size: 40rpx;
  color: #9ca3af;
}

.modal-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-user-info {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.dark .modal-user-info {
  color: #9ca3af;
}

.highlight {
  font-weight: 700;
  color: #1f2937;
}

.dark .highlight {
  color: #ffffff;
}

/* 头像选择 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
}

.avatar-preview:active .avatar-overlay {
  opacity: 1;
}

.avatar-overlay text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
}

.avatar-grid {
  margin-top: 24rpx;
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.dark .avatar-grid {
  background-color: #374151;
}

.avatar-option {
  aspect-ratio: 1;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.avatar-option.selected {
  border-color: #ef4444;
  transform: scale(1.1);
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.dark .form-label {
  color: #ffffff;
}

.form-hint {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.dark .form-hint {
  color: #9ca3af;
}

.form-input {
  width: 100%;
  padding: 24rpx 20rpx;
  background-color: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
  min-height: 88rpx;
}

.dark .form-input {
  background-color: #374151;
  border-color: #4b5563;
  color: #ffffff;
}

.form-input:focus {
  border-color: #ef4444;
}

.points-input {
  font-size: 36rpx;
  font-family: monospace;
  text-align: center;
}

.form-picker {
  width: 100%;
  padding: 24rpx 20rpx;
  background-color: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.dark .form-picker {
  background-color: #374151;
  border-color: #4b5563;
}

.picker-value {
  font-size: 28rpx;
  color: #1f2937;
}

.dark .picker-value {
  color: #ffffff;
}

/* 单选按钮 */
.radio-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.radio-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
}

.dark .radio-option {
  border-color: #374151;
}

.radio-option.selected {
  border-color: #ef4444;
  background-color: #fef2f2;
}

.dark .radio-option.selected {
  background-color: rgba(239, 68, 68, 0.1);
}

.radio-circle {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #d1d5db;
  border-radius: 50%;
  margin-right: 16rpx;
}

.radio-circle.checked {
  border-color: #ef4444;
  background-color: #ef4444;
}

.radio-label {
  font-size: 26rpx;
  color: #1f2937;
}

.dark .radio-label {
  color: #ffffff;
}

/* 危险区域 */
.danger-zone {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f3f4f6;
}

.dark .danger-zone {
  border-top-color: #374151;
}

.delete-user-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #fef2f2;
  color: #dc2626;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.dark .delete-user-btn {
  background-color: rgba(239, 68, 68, 0.15);
  color: #fca5a5;
}

.delete-user-btn::after {
  border: none;
}

/* 模态框底部 */
.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background-color: #f9fafb;
}

.dark .modal-footer {
  background-color: #374151;
}

.btn-cancel {
  flex: 1;
  padding: 20rpx;
  background-color: transparent;
  color: #6b7280;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.dark .btn-cancel {
  color: #9ca3af;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  padding: 20rpx;
  background-color: #3b82f6;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.btn-confirm.danger {
  background-color: #ef4444;
}

.btn-confirm::after {
  border: none;
}

/* 底部安全区域 */
.bottom-safe-area {
  height: 100rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
