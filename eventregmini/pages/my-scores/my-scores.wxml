<!--
  我的积分页面
  与网页版 MyScores.tsx 布局完全一致
-->

<view class="page {{theme === 'dark' ? 'dark' : ''}}">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="header-left">
      <text class="app-logo">🏆</text>
      <text class="app-name">有熊来集</text>
    </view>
    <view class="header-right">
      <view class="theme-btn" bindtap="toggleTheme">
        <text>{{theme === 'light' ? '🌙' : '☀️'}}</text>
      </view>
      <message-center theme="{{theme}}"></message-center>
    </view>
  </view>
  
  <scroll-view class="main-content" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 积分概览卡片 -->
    <view class="overview-card">
      <view class="overview-bg-circle large"></view>
      <view class="overview-bg-circle small"></view>
      
      <view class="overview-content">
        <!-- 用户头像和信息 -->
        <view class="user-row">
          <view class="user-avatar">
            <image src="{{userInfo.avatar}}" mode="aspectFill" />
          </view>
          <view class="user-info">
            <view class="user-name-row">
              <text class="user-nickname">{{userInfo.nickname || '用户'}}</text>
              <view class="edit-btn" bindtap="openEditProfile">
                <text>编辑资料</text>
              </view>
              <view class="logout-btn" bindtap="handleLogout">
                <text>退出登录</text>
              </view>
            </view>
            <text class="user-subtitle">个人中心</text>
          </view>
        </view>
        
        <!-- 数据统计 -->
        <view class="stats-grid">
          <view class="stat-item">
            <text class="stat-value">{{totalPoints}}</text>
            <text class="stat-label">总积分</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{currentRank || '-'}}</text>
            <text class="stat-label">当前排名</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{recentRecords.length}}</text>
            <text class="stat-label">参加次数</text>
          </view>
        </view>
        
        <!-- 查看排行榜按钮 -->
        <button class="rankings-btn" bindtap="goToRankings">查看排行榜</button>
      </view>
    </view>
    
    <!-- 最近积分记录 -->
    <view class="card">
      <view class="card-header">
        <view class="card-title">
          <text class="title-icon">🏆</text>
          <text>最近积分记录</text>
        </view>
      </view>
      
      <view class="records-list" wx:if="{{recentRecords.length > 0}}">
        <view wx:for="{{recentRecords}}" wx:key="id" class="record-item">
          <view class="record-left">
            <view class="record-icon {{item.status}}">🏆</view>
            <view class="record-info">
              <text class="record-name">{{item.tournamentName}}</text>
              <text class="record-date">{{item.formattedDate}}</text>
            </view>
          </view>
          <view class="record-right">
            <text class="record-points {{item.points > 0 ? 'positive' : 'negative'}}">
              {{item.points > 0 ? '+' : ''}}{{item.points}}
            </text>
            <view class="record-status {{item.status}}">{{item.statusText}}</view>
          </view>
        </view>
      </view>
      
      <!-- 空状态 -->
      <view wx:else class="empty-state">
        <view class="empty-icon">🏆</view>
        <text class="empty-text">暂无积分记录</text>
      </view>
    </view>
    
    <!-- 积分趋势 -->
    <view class="card">
      <view class="card-header">
        <view class="card-title">
          <text class="title-icon">📊</text>
          <text>积分趋势</text>
        </view>
        <text class="card-action">详情</text>
      </view>
      
      <!-- 简化的趋势图（小程序不支持Recharts，使用简化版） -->
      <view class="chart-area">
        <view class="chart-bars">
          <view 
            wx:for="{{scoreHistory}}" 
            wx:key="name" 
            class="chart-bar-wrapper"
          >
            <view class="chart-bar" style="height: {{item.height}}rpx;"></view>
            <text class="chart-label">{{item.name}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 积分规则说明 -->
    <view class="card">
      <view class="card-header">
        <view class="card-title">积分规则</view>
      </view>
      
      <view class="rules-list">
        <view class="rule-item">
          <view class="rule-number">1</view>
          <text class="rule-text">成功报名且为上场人员的用户，在活动结束后自动获得10积分</text>
        </view>
        <view class="rule-item">
          <view class="rule-number">2</view>
          <text class="rule-text">活动获得前三名可额外获得积分奖励</text>
        </view>
        <view class="rule-item">
          <view class="rule-number">3</view>
          <text class="rule-text">积分可用于兑换活动优先权、纪念品等奖励</text>
        </view>
      </view>
    </view>
    
    <view class="bottom-safe-area"></view>
  </scroll-view>
  
  <!-- 编辑资料模态框 -->
  <view wx:if="{{showEditModal}}" class="modal-overlay" bindtap="closeEditModal">
    <view class="modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑个人资料</text>
        <view class="modal-close" bindtap="closeEditModal">
          <text>✕</text>
        </view>
      </view>
      
      <view class="modal-body">
        <!-- 头像选择 -->
        <view class="avatar-section">
          <view class="current-avatar" bindtap="toggleAvatarSelection">
            <image src="{{editAvatar}}" mode="aspectFill" />
            <view class="avatar-overlay">更换</view>
          </view>
          
          <view wx:if="{{showAvatarSelection}}" class="avatar-selection-area">
            <!-- 微信头像按钮 -->
            <button class="wx-avatar-choose-btn" open-type="chooseAvatar" bindchooseavatar="onChooseWxAvatar">
              <text>使用微信头像</text>
            </button>
            
            <!-- 默认头像网格 -->
            <view class="avatar-grid">
              <view 
                wx:for="{{avatars}}" 
                wx:key="*this" 
                class="avatar-option {{editAvatar === item ? 'selected' : ''}}"
                bindtap="selectAvatar"
                data-avatar="{{item}}"
              >
                <image src="{{item}}" mode="aspectFill" />
              </view>
            </view>
          </view>
        </view>
        
        <!-- 昵称 -->
        <view class="form-group">
          <text class="form-label">昵称</text>
          <input 
            class="form-input" 
            value="{{editNickname}}" 
            bindinput="onNicknameInput"
            placeholder="请输入昵称"
            placeholder-class="input-placeholder"
          />
        </view>
        
        <!-- 新密码 -->
        <view class="form-group">
          <text class="form-label">新密码 (留空不修改)</text>
          <input 
            class="form-input" 
            value="{{editPassword}}" 
            bindinput="onPasswordInput"
            placeholder="请输入新密码"
            placeholder-class="input-placeholder"
          />
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeEditModal">取消</button>
        <button class="btn-save" bindtap="handleUpdateProfile">
          <text>保存修改</text>
        </button>
      </view>
    </view>
  </view>
</view>
