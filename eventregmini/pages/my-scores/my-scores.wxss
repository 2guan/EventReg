/**
 * 我的积分页面样式
 * 与网页版 MyScores.tsx 样式完全一致
 */

.page {
  min-height: 100vh;
  background-color: #f9fafb;
  display: flex;
  flex-direction: column;
}

.page.dark {
  background-color: #111827;
}

/* 顶部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 30;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.dark .header {
  background-color: #1f2937;
}

.back-btn,
.theme-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 40rpx;
  color: #1f2937;
}

.dark .back-btn,
.dark .theme-btn {
  color: #ffffff;
}

.header-left {
  display: flex;
  align-items: center;
}

.app-logo {
  font-size: 48rpx;
  margin-right: 12rpx;
}

.app-name {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(to right, #ef4444, #fb923c);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .header-title {
  color: #ffffff;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding: 24rpx;
}

/* 积分概览卡片 */
.overview-card {
  background: linear-gradient(to right, #ef4444, #fb923c);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
  position: relative;
  overflow: hidden;
}

.overview-bg-circle {
  position: absolute;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.overview-bg-circle.large {
  width: 320rpx;
  height: 320rpx;
  right: -80rpx;
  top: -80rpx;
}

.overview-bg-circle.small {
  width: 256rpx;
  height: 256rpx;
  right: 80rpx;
  bottom: -80rpx;
}

.overview-content {
  position: relative;
  z-index: 1;
}

/* 用户信息行 */
.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  overflow: hidden;
  background-color: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-info {
  margin-left: 24rpx;
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 700;
}

.edit-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(0, 0, 0, 0.2);
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.edit-icon {
  font-size: 24rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(0, 0, 0, 0.2);
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.logout-icon {
  font-size: 24rpx;
}

.user-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.8;
  margin-top: 6rpx;
}

/* 数据统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  opacity: 0.8;
}

/* 查看排行榜按钮 */
.rankings-btn {
  width: 100%;
  padding: 20rpx;
  background-color: rgba(0, 0, 0, 0.2);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
}

.rankings-btn::after {
  border: none;
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #f3f4f6;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.03);
}

.dark .card {
  background-color: #1f2937;
  border-color: #374151;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .card-title {
  color: #ffffff;
}

.title-icon {
  margin-right: 16rpx;
  font-size: 36rpx;
}

.card-action {
  font-size: 26rpx;
  color: #ef4444;
}

/* 积分记录列表 */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
}

.dark .record-item {
  background-color: #374151;
}

.record-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-icon.win {
  background-color: #dcfce7;
}

.record-icon.lose {
  background-color: #fee2e2;
}

.record-icon.participation {
  background-color: #dbeafe;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dark .record-name {
  color: #ffffff;
}

.record-date {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.dark .record-date {
  color: #9ca3af;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  flex-shrink: 0;
  margin-bottom: 20rpx; /* Move up by approx 10rpx relative to center */
  margin-right: 10rpx; /* Move left by 10rpx */
}

.record-points {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.record-points.positive {
  color: #ef4444;
}

.record-points.negative {
  color: #6b7280;
}

.record-status {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
}

.record-status.win {
  background-color: #dcfce7;
  color: #166534;
}

.dark .record-status.win {
  background-color: rgba(34, 197, 94, 0.2);
  color: #86efac;
}

.record-status.lose {
  background-color: #fee2e2;
  color: #991b1b;
}

.dark .record-status.lose {
  background-color: rgba(239, 68, 68, 0.2);
  color: #fca5a5;
}

.record-status.participation {
  background-color: #dbeafe;
  color: #1e40af;
}

.dark .record-status.participation {
  background-color: rgba(59, 130, 246, 0.2);
  color: #93c5fd;
}

/* 空状态 */
.empty-state {
  padding: 64rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 48rpx;
  display: inline-block;
  background-color: #f3f4f6;
  padding: 24rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.dark .empty-icon {
  background-color: #374151;
}

.empty-text {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
}

.dark .empty-text {
  color: #9ca3af;
}

/* 图表区域 */
.chart-area {
  height: 400rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 20rpx 0;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  width: 100%;
  height: 100%;
}

.chart-bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.chart-bar {
  width: 32rpx;
  background: linear-gradient(to top, #ef4444, #fca5a5);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s;
}

.chart-label {
  font-size: 20rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.dark .chart-label {
  color: #9ca3af;
}

/* 规则列表 */
.rules-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
}

.rule-number {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #fee2e2;
  color: #ef4444;
  font-size: 22rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.dark .rule-number {
  background-color: rgba(239, 68, 68, 0.2);
}

.rule-text {
  flex: 1;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.5;
}

.dark .rule-text {
  color: #d1d5db;
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal {
  width: 100%;
  max-width: 640rpx;
  max-height: 90vh;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.dark .modal {
  background-color: #1f2937;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.dark .modal-header {
  border-color: #374151;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .modal-title {
  color: #ffffff;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 40rpx;
}

.modal-body {
  padding: 32rpx;
  overflow-y: auto;
  flex: 1;
}

/* 头像选择区 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.current-avatar {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid #f3f4f6;
}

.dark .current-avatar {
  border-color: #374151;
}

.current-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0;
}

.current-avatar:active .avatar-overlay {
  opacity: 1;
}

/* 头像选择区域 */
.avatar-selection-area {
  margin-top: 24rpx;
  width: 100%;
}

.wx-avatar-choose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 20rpx 24rpx;
  background: linear-gradient(to right, #07c160, #10b981);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
  margin-bottom: 20rpx;
}

.wx-avatar-choose-btn::after {
  border: none;
}

.wx-avatar-choose-btn .wx-icon {
  font-size: 32rpx;
}

.avatar-grid {
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 24rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  width: 100%;
}

.dark .avatar-grid {
  background-color: #374151;
}

.avatar-option {
  aspect-ratio: 1;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid transparent;
}

.avatar-option.selected {
  border-color: #ef4444;
  transform: scale(1.1);
}

.avatar-option image {
  width: 100%;
  height: 100%;
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.dark .form-label {
  color: #ffffff;
}

.form-input {
  width: 100%;
  padding: 28rpx 24rpx;
  min-height: 96rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2937;
  background-color: #ffffff;
  box-sizing: border-box;
}

.dark .form-input {
  background-color: #374151;
  border-color: #4b5563;
  color: #ffffff;
}

.input-placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

/* 模态框底部 */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background-color: #f9fafb;
}

.dark .modal-footer {
  background-color: #374151;
}

.btn-cancel {
  flex: 1;
  padding: 20rpx;
  background-color: transparent;
  color: #4b5563;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.dark .btn-cancel {
  color: #d1d5db;
}

.btn-cancel::after {
  border: none;
}

.btn-save {
  flex: 1;
  padding: 20rpx;
  background-color: #ef4444;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.btn-save::after {
  border: none;
}

/* 底部安全区域 */
.bottom-safe-area {
  height: 180rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
