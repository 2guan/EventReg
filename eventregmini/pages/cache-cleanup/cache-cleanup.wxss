/**
 * 缓存日志清理页面样式
 */

.page {
  min-height: 100vh;
  background: #f3f4f6;
  display: flex;
  flex-direction: column;
}

.page.dark {
  background: #111827;
  color: #fff;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.page.dark .header {
  background: #1f2937;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.back-btn, .theme-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 36rpx;
}

.back-btn:active, .theme-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.page.dark .back-btn:active,
.page.dark .theme-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding: 24rpx;
}

/* 说明信息卡片 */
.info-card {
  display: flex;
  align-items: flex-start;
  background: #eff6ff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.info-card.warning {
  background: #fff7ed;
}

.page.dark .info-card {
  background: rgba(59, 130, 246, 0.15);
}

.page.dark .info-card.warning {
  background: rgba(249, 115, 22, 0.15);
}

.info-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.info-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #ea580c;
  display: block;
}

.page.dark .info-title {
  color: #fdba74;
}

.info-desc {
  font-size: 24rpx;
  color: #f97316;
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}

.page.dark .info-desc {
  color: #fdba74;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #ef4444;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #9ca3af;
}

/* 清理项列表 */
.cleanup-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cleanup-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.page.dark .cleanup-item {
  background: #1f2937;
}

.item-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  margin-right: 20rpx;
}

.item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-icon.blue { background: #dbeafe; }
.item-icon.yellow { background: #fef3c7; }
.item-icon.green { background: #d1fae5; }
.item-icon.purple { background: #ede9fe; }
.item-icon.orange { background: #ffedd5; }
.item-icon.red { background: #fee2e2; }

.page.dark .item-icon.blue { background: rgba(59, 130, 246, 0.3); }
.page.dark .item-icon.yellow { background: rgba(234, 179, 8, 0.3); }
.page.dark .item-icon.green { background: rgba(34, 197, 94, 0.3); }
.page.dark .item-icon.purple { background: rgba(139, 92, 246, 0.3); }
.page.dark .item-icon.orange { background: rgba(249, 115, 22, 0.3); }
.page.dark .item-icon.red { background: rgba(239, 68, 68, 0.3); }

.item-info {
  flex: 1;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
}

.page.dark .item-name {
  color: #f3f4f6;
}

.empty-tag {
  font-size: 20rpx;
  background: #f3f4f6;
  color: #6b7280;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.page.dark .empty-tag {
  background: #374151;
}

.item-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
  line-height: 1.4;
}

.page.dark .item-desc {
  color: #9ca3af;
}

.item-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.stat-text {
  font-size: 24rpx;
  color: #4b5563;
}

.page.dark .stat-text {
  color: #d1d5db;
}

/* 清理按钮 */
.cleanup-btn {
  width: 120rpx !important;
  min-width: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  background: #ef4444;
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  line-height: 1;
  flex-shrink: 0;
}

.cleanup-btn::after {
  border: none;
}

.cleanup-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.page.dark .cleanup-btn.disabled {
  background: #374151;
  color: #6b7280;
}

.btn-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.btn-text {
  margin-left: 4rpx;
}

/* 一键清理 */
.cleanup-all-section {
  margin-top: 32rpx;
}

.cleanup-all-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #ef4444, #f97316);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.cleanup-all-btn.disabled {
  background: #d1d5db;
}

.page.dark .cleanup-all-btn.disabled {
  background: #374151;
  color: #6b7280;
}

/* 底部安全区域 */
.bottom-safe-area {
  height: calc(48rpx + env(safe-area-inset-bottom));
}
