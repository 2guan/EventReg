/**
 * 积分排行榜页面样式
 * 与网页版 Rankings.tsx 样式完全一致
 */

.page {
  min-height: 100vh;
  background-color: #f9fafb;
  display: flex;
  flex-direction: column;
}

.page.dark {
  background-color: #111827;
}

/* 顶部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.dark .header {
  background-color: #1f2937;
}

.back-btn,
.theme-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 40rpx;
  color: #1f2937;
}

.dark .back-btn,
.dark .theme-btn {
  color: #ffffff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .header-title {
  color: #ffffff;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding: 24rpx;
}

/* 前三名展示区 */
.top-stars-section {
  margin-bottom: 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 24rpx;
}

.dark .section-title {
  color: #ffffff;
}

.title-icon {
  margin-right: 16rpx;
  font-size: 40rpx;
}

/* 前三名网格 */
.top-three-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.top-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #e5e7eb;
  position: relative;
}

.dark .top-card {
  background-color: #1f2937;
  border-color: #374151;
}

.top-card.first {
  border: 4rpx solid #fbbf24;
}

.champion-label {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #fbbf24;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.top-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f3f4f6;
  margin-bottom: 16rpx;
}

.dark .top-avatar {
  background-color: #374151;
}

.top-card.first .top-avatar {
  width: 140rpx;
  height: 140rpx;
  margin-top: 16rpx;
}

.top-avatar.gold-ring {
  background-color: #fef3c7;
}

.dark .top-avatar.gold-ring {
  background-color: rgba(251, 191, 36, 0.2);
}

.top-avatar image {
  width: 100%;
  height: 100%;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.rank-badge.gold {
  background-color: #fbbf24;
  width: 56rpx;
  height: 56rpx;
  font-size: 28rpx;
}

.rank-badge.silver {
  background-color: #9ca3af;
}

.rank-badge.bronze {
  background-color: #fb923c;
}

.top-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 6rpx;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dark .top-name {
  color: #ffffff;
}

.top-name.bold {
  font-weight: 700;
  font-size: 28rpx;
}

.top-points {
  font-size: 22rpx;
  color: #6b7280;
}

.dark .top-points {
  color: #9ca3af;
}

.top-points.gold-text {
  color: #f59e0b;
  font-weight: 500;
}

/* 搜索区域 */
.search-section {
  margin-bottom: 24rpx;
}

.search-bar {
  position: relative;
  margin-bottom: 24rpx;
}

.search-icon {
  position: absolute;
  left: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  z-index: 1;
  line-height: 1;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx 0 72rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #ffffff;
  box-sizing: border-box;
  line-height: 80rpx;
}

.dark .search-input {
  background-color: #1f2937;
  border-color: #374151;
  color: #ffffff;
}

.search-placeholder {
  color: #9ca3af;
}

/* 标签切换 */
.tabs-row {
  display: flex;
  gap: 16rpx;
}

.tab {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  background-color: #ffffff;
  color: #6b7280;
  border: 2rpx solid #e5e7eb;
}

.dark .tab {
  background-color: #1f2937;
  border-color: #374151;
  color: #9ca3af;
}

.tab.active {
  background-color: #ef4444;
  color: #ffffff;
  border-color: #ef4444;
}

/* 我的排名卡片 */
.my-rank-card {
  background: linear-gradient(to right, #ef4444, #fb923c);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  color: #ffffff;
}

.my-rank-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.my-rank-avatar image {
  width: 100%;
  height: 100%;
}

.my-rank-info {
  margin-left: 24rpx;
  flex: 1;
}

.my-rank-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
}

.my-rank-position {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.my-rank-points {
  text-align: right;
}

.points-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.points-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
}

/* 排行榜列表卡片 */
.rank-list-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  border: 2rpx solid #f3f4f6;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.03);
}

.dark .rank-list-card {
  background-color: #1f2937;
  border-color: #374151;
}

.card-header {
  padding: 28rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.dark .card-header {
  border-color: #374151;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .card-title {
  color: #ffffff;
}

/* 排行项 */
.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.dark .rank-item {
  border-color: #374151;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-item.is-me {
  background-color: #fef2f2;
}

.dark .rank-item.is-me {
  background-color: rgba(239, 68, 68, 0.1);
}

.rank-number {
  width: 64rpx;
  text-align: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-badge-inline {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.rank-badge-inline.gold {
  background-color: #fef3c7;
  color: #d97706;
}

.dark .rank-badge-inline.gold {
  background-color: rgba(251, 191, 36, 0.2);
  color: #fcd34d;
}

.rank-badge-inline.silver {
  background-color: #f3f4f6;
  color: #4b5563;
}

.dark .rank-badge-inline.silver {
  background-color: #374151;
  color: #d1d5db;
}

.rank-badge-inline.bronze {
  background-color: #ffedd5;
  color: #ea580c;
}

.dark .rank-badge-inline.bronze {
  background-color: rgba(251, 146, 60, 0.2);
  color: #fdba74;
}

.rank-text {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 500;
}

.rank-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}

.rank-avatar.my-ring {
  border: 4rpx solid #ef4444;
}

.rank-avatar image {
  width: 100%;
  height: 100%;
}

.me-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background-color: #ef4444;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.rank-name-wrapper {
  flex: 1;
  min-width: 0;
}

.rank-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dark .rank-name {
  color: #ffffff;
}

.rank-name.my-name {
  color: #ef4444;
}

.rank-points-wrapper {
  text-align: right;
  flex-shrink: 0;
}

.rank-points-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .rank-points-value {
  color: #ffffff;
}

.rank-points-label {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
}

.dark .rank-points-label {
  color: #9ca3af;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 64rpx;
  display: inline-block;
  background-color: #f3f4f6;
  padding: 32rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.dark .empty-icon {
  background-color: #374151;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.dark .empty-title {
  color: #ffffff;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
}

.dark .empty-desc {
  color: #9ca3af;
}

/* 底部安全区域 */
.bottom-safe-area {
  height: 100rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
