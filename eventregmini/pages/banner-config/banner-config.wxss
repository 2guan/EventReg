/**
 * 活动图片配置页面样式
 */

.page {
  min-height: 100vh;
  background: #f3f4f6;
  display: flex;
  flex-direction: column;
}

.page.dark {
  background: #111827;
  color: #fff;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.page.dark .header {
  background: #1f2937;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.back-btn, .theme-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 36rpx;
}

.back-btn:active, .theme-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.page.dark .back-btn:active,
.page.dark .theme-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding: 24rpx;
}

/* 说明信息卡片 */
.info-card {
  display: flex;
  align-items: flex-start;
  background: #eff6ff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.page.dark .info-card {
  background: rgba(59, 130, 246, 0.15);
}

.info-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.info-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2563eb;
  display: block;
}

.page.dark .info-title {
  color: #93c5fd;
}

.info-desc {
  font-size: 24rpx;
  color: #3b82f6;
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}

.page.dark .info-desc {
  color: #93c5fd;
}

/* 区域标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
}

/* 上传自定义封面按钮 */
.upload-custom-btn {
  min-width: 0 !important;
  width: auto !important;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  background: #ef4444;
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  line-height: 1.2;
}

.upload-custom-btn::after {
  border: none;
}

.upload-custom-btn.disabled {
  background: #fca5a5;
}

/* 空自定义封面提示 */
.empty-custom {
  text-align: center;
  padding: 60rpx 0;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx dashed #d1d5db;
  margin-bottom: 16rpx;
}

.page.dark .empty-custom {
  background: #1f2937;
  border-color: #4b5563;
}

.empty-text {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #ef4444;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #9ca3af;
}

/* Banner 网格 */
.banner-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.banner-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.page.dark .banner-card {
  background: #1f2937;
}

/* 图片预览 */
.banner-image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 18.75%; /* 16:3 = 3/16 = 18.75% */
  background: #f3f4f6;
}

.page.dark .banner-image-wrapper {
  background: #374151;
}

.banner-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 上传遮罩 */
.upload-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* 操作区域 */
.banner-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
}

.banner-label {
  flex: 1;
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

.banner-label.custom-label {
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.page.dark .banner-label {
  color: #9ca3af;
}

.replace-btn {
  min-width: 0 !important;
  width: auto !important;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 48rpx;
  background: #6b7280;
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  line-height: 1;
}

.replace-btn::after {
  border: none;
}

.replace-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.page.dark .replace-btn.disabled {
  background: #374151;
  color: #6b7280;
}

/* 删除按钮 */
.delete-btn {
  min-width: 0 !important;
  width: auto !important;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 36rpx;
  background: transparent;
  color: #ef4444;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: 2rpx solid #ef4444;
  line-height: 1;
}

.delete-btn::after {
  border: none;
}

/* 底部安全区域 */
.bottom-safe-area {
  height: calc(48rpx + env(safe-area-inset-bottom));
}
