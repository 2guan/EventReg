/**
 * 登录页面样式
 * 与网页版 Login.tsx 样式完全一致
 */

.page {
  min-height: 100vh;
  background-color: #f9fafb;
}

.page.dark {
  background-color: #111827;
}

/* 顶部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.dark .header {
  background-color: #1f2937;
}

.back-btn,
.theme-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.back-btn:active,
.theme-btn:active {
  background-color: #f3f4f6;
}

.dark .back-btn:active,
.dark .theme-btn:active {
  background-color: #374151;
}

.icon-back {
  font-size: 40rpx;
  color: #1f2937;
}

.dark .icon-back {
  color: #ffffff;
}

.icon-theme {
  font-size: 40rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .header-title {
  color: #ffffff;
}

/* 主内容区 */
.main-content {
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 64rpx;
  margin-bottom: 80rpx;
}

.logo-container {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(to right, #ef4444, #fb923c);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.logo-icon {
  font-size: 96rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(to right, #ef4444, #fb923c);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.app-subtitle {
  font-size: 28rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.dark .app-subtitle {
  color: #9ca3af;
}

/* 表单区域 */
.form-section {
  width: 100%;
  max-width: 640rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
  color: #1f2937;
}

.dark .form-label {
  color: #e5e7eb;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.form-input {
  width: 100%;
  padding: 28rpx 32rpx;
  padding-right: 80rpx;
  min-height: 96rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e5e7eb;
  background-color: #ffffff;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.dark .form-input {
  background-color: #1f2937;
  border-color: #374151;
  color: #ffffff;
}

.form-input-placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

.input-wrapper.input-error .form-input {
  border-color: #ef4444;
}

.toggle-password {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 8rpx;
}

.toggle-password text {
  font-size: 40rpx;
}

.error-text {
  display: block;
  font-size: 24rpx;
  color: #ef4444;
  margin-top: 8rpx;
}

/* 登录按钮 */
.submit-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(to right, #ef4444, #fb923c);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-top: 16rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.7;
}

.submit-btn:active {
  opacity: 0.9;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background-color: #e5e7eb;
}

.dark .divider-line {
  background-color: #374151;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.dark .divider-text {
  color: #9ca3af;
}

/* 微信登录按钮 */
.wx-login-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 24rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-login-btn::after {
  border: none;
}

.wx-login-btn[disabled] {
  opacity: 0.7;
}

.wx-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

/* 注册链接 */
.register-link {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
}

.register-text {
  font-size: 28rpx;
  color: #6b7280;
}

.dark .register-text {
  color: #9ca3af;
}

.register-action {
  font-size: 28rpx;
  color: #ef4444;
  font-weight: 500;
  margin-left: 8rpx;
}

.register-action:active {
  color: #dc2626;
}

/* 微信资料获取模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.wx-profile-modal {
  width: 100%;
  max-width: 640rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.dark .wx-profile-modal {
  background-color: #1f2937;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.dark .modal-header {
  border-color: #374151;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .modal-title {
  color: #ffffff;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close text {
  font-size: 40rpx;
  color: #9ca3af;
}

.modal-body {
  padding: 32rpx;
}

.modal-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 32rpx;
}

.dark .modal-hint {
  color: #9ca3af;
}

/* 头像选择 */
.wx-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.wx-avatar-btn {
  width: 140rpx !important;
  height: 140rpx !important;
  min-width: 140rpx;
  min-height: 140rpx;
  max-width: 140rpx;
  max-height: 140rpx;
  padding: 0 !important;
  margin: 0;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f3f4f6;
  border: 4rpx dashed #d1d5db;
  line-height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-avatar-btn::after {
  border: none;
}

.dark .wx-avatar-btn {
  background-color: #374151;
  border-color: #4b5563;
}

.wx-avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.wx-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 48rpx;
}

.wx-avatar-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.dark .wx-avatar-hint {
  color: #6b7280;
}

/* 昵称输入 */
.wx-nickname-section {
  margin-bottom: 16rpx;
}

.section-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.dark .section-label {
  color: #ffffff;
}

.wx-nickname-input {
  width: 100%;
  padding: 28rpx 24rpx;
  min-height: 96rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2937;
  background-color: #ffffff;
  box-sizing: border-box;
}

.dark .wx-nickname-input {
  background-color: #374151;
  border-color: #4b5563;
  color: #ffffff;
}

/* 模态框底部 */
.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background-color: #f9fafb;
}

.dark .modal-footer {
  background-color: #374151;
}

.btn-cancel {
  flex: 1;
  padding: 20rpx;
  background-color: transparent;
  color: #6b7280;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  padding: 20rpx;
  background: linear-gradient(to right, #ef4444, #fb923c);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm[disabled] {
  opacity: 0.5;
}
