<!--
  管理中心页面
  与网页版 Admin.tsx 布局完全一致
-->

<view class="page {{theme === 'dark' ? 'dark' : ''}}">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="home-btn" bindtap="goToHome">
      <text>返回首页</text>
    </view>
    <text class="header-title">管理中心</text>
    <view class="header-right">
      <view class="theme-btn" bindtap="toggleTheme">
        <text>{{theme === 'light' ? '🌙' : '☀️'}}</text>
      </view>
      <message-center theme="{{theme}}" />
    </view>
  </view>
  
  <!-- 主内容区 -->
  <scroll-view class="main-content" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 管理员信息卡片 -->
    <view class="admin-banner">
      <view class="banner-circle-1"></view>
      <view class="banner-circle-2"></view>
      <view class="banner-content">
        <view class="banner-icon">
          <text>👤</text>
        </view>
        <view class="banner-info">
          <text class="banner-title">管理员中心</text>
          <text class="banner-subtitle">欢迎回来，{{userInfo.nickname || '管理员'}}</text>
        </view>
      </view>
    </view>
    
    <!-- 数据概览 -->
    <view class="stats-grid">
      <view class="stat-card">
        <view class="stat-icon blue">
          <text>📅</text>
        </view>
        <view class="stat-info">
          <text class="stat-label">总活动数</text>
          <text class="stat-value">{{tournaments.length}}</text>
        </view>
      </view>
      <view class="stat-card">
        <view class="stat-icon red">
          <text>👥</text>
        </view>
        <view class="stat-info">
          <text class="stat-label">待审核用户</text>
          <text class="stat-value">{{pendingUsers.length}}</text>
        </view>
      </view>
    </view>
    
    <!-- 管理功能标签页 -->
    <view class="admin-card">
      <!-- 标签切换 -->
      <view class="tabs">
        <view 
          wx:for="{{tabs}}" 
          wx:key="key"
          class="tab-item {{activeTab === item.key ? 'active' : ''}}"
          data-tab="{{item.key}}"
          bindtap="onTabChange"
        >
          {{item.label}}
        </view>
      </view>
      
      <!-- 内容区域 -->
      <view class="card-content">
        <!-- 活动管理 -->
        <view wx:if="{{activeTab === 'tournaments'}}" class="tab-content">
          <view class="content-header">
            <view class="title-with-filter">
              <text class="content-title">活动列表</text>
              <picker 
                mode="selector" 
                range="{{statusOptions}}" 
                range-key="label"
                bindchange="onStatusFilterChange"
                value="{{0}}"
              >
                <view class="filter-btn">
                  <text class="filter-icon">🔽</text>
                  <text>{{statusFilterLabel}}</text>
                </view>
              </picker>
            </view>
            <button class="create-btn" bindtap="goToCreateTournament">
              <text class="btn-icon">+</text>
              <text>创建活动</text>
            </button>
          </view>
          
          <!-- 活动列表 -->
          <view wx:if="{{loading}}" class="loading-container">
            <view class="loading-spinner"></view>
          </view>
          
          <view wx:elif="{{tournaments.length > 0}}" class="tournament-list">
            <block wx:for="{{tournaments}}" wx:key="id">
              <view 
                wx:if="{{statusFilter === 'all' || item.status === statusFilter}}"
                class="tournament-item"
                data-id="{{item.id}}"
                bindtap="goToEditTournament"
              >
              <view class="tournament-info">
                <view class="tournament-title-row">
                  <text class="tournament-name">{{item.name}}</text>
                  <text class="status-tag {{item.statusClass}}">{{item.statusText}}</text>
                </view>
                <view class="tournament-meta">
                  <text>📅 {{item.formattedDateTime}}</text>
                </view>
              </view>
              <view class="tournament-actions" catchtap="stopPropagation">
                <view 
                  class="action-btn delete" 
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                  catchtap="deleteTournament"
                >
                  <text>🗑️</text>
                </view>
              </view>
              </view>
            </block>
          </view>
          
          <view wx:else class="empty-state">
            <text class="empty-icon">📅</text>
            <text class="empty-title">暂无活动</text>
            <text class="empty-desc">点击"创建活动"按钮添加新的活动</text>
          </view>
        </view>
        
        <!-- 用户管理 -->
        <view wx:elif="{{activeTab === 'users'}}" class="tab-content">
          <view class="content-header">
            <text class="content-title">待审核用户</text>
          </view>
          
          <view wx:if="{{loading}}" class="loading-container">
            <view class="loading-spinner"></view>
          </view>
          
          <block wx:else>
            <view wx:if="{{pendingUsers.length > 0}}" class="user-list">
              <view 
                wx:for="{{pendingUsers}}" 
                wx:key="id" 
                class="user-item"
              >
                <image class="user-avatar" src="{{item.avatar}}" mode="aspectFill" />
                <view class="user-info">
                  <text class="user-name">{{item.nickname || item.username}}</text>
                  <text class="user-username">@{{item.username}}</text>
                </view>
                <view class="user-actions">
                  <view class="action-btn approve" data-id="{{item.id}}" catchtap="approveUser">
                    <text>✓</text>
                  </view>
                  <view class="action-btn reject" data-id="{{item.id}}" catchtap="rejectUser">
                    <text>✗</text>
                  </view>
                </view>
              </view>
            </view>
            
            <view wx:else class="empty-state">
              <text class="empty-icon">👥</text>
              <text class="empty-title">暂无待审核用户</text>
              <text class="empty-desc">所有用户均已审核</text>
            </view>
          </block>
          
          <!-- 查看全部用户 -->
          <view class="section-btn">
            <button class="view-all-btn" bindtap="goToAdminUsers">
              查看所有用户
            </button>
          </view>
        </view>
        
        <!-- 系统设置 -->
        <view wx:elif="{{activeTab === 'settings'}}" class="tab-content">
          <view class="content-header">
            <text class="content-title">系统设置</text>
          </view>
          
          <view class="settings-list">
            <view class="setting-item">
              <view class="setting-icon blue">
                <text>⚙️</text>
              </view>
              <view class="setting-info">
                <text class="setting-title">全局通知开关</text>
                <text class="setting-desc">开启后，系统将在活动状态变更、候补成功等重要时刻向用户发送通知。</text>
              </view>
              <switch 
                class="setting-switch" 
                checked="{{notificationEnabled}}"
                color="#ef4444"
                bindchange="toggleNotification"
              />
            </view>

            <!-- 微信推送开关 -->
            <view class="setting-item">
              <view class="setting-icon green">
                <text>📱</text>
              </view>
              <view class="setting-info">
                <text class="setting-title">微信消息推送</text>
                <text class="setting-desc">开启后，系统将通过微信订阅消息向用户推送重要通知。需用户授权后生效。</text>
              </view>
              <switch 
                class="setting-switch" 
                checked="{{wxPushEnabled}}"
                color="#22c55e"
                bindchange="toggleWxPush"
              />
            </view>

            <!-- 活动日志入口 -->
            <view class="setting-item clickable" bindtap="goToActivityLog">
              <view class="setting-icon purple">
                <text>📋</text>
              </view>
              <view class="setting-info">
                <text class="setting-title">活动日志</text>
                <text class="setting-desc">查看所有活动的报名记录和操作日志。</text>
              </view>
              <view class="setting-arrow">
                <text>→</text>
              </view>
            </view>

            <!-- 活动图片配置入口 -->
            <view class="setting-item clickable" bindtap="goToBannerConfig">
              <view class="setting-icon green">
                <text>🖼️</text>
              </view>
              <view class="setting-info">
                <text class="setting-title">活动图片配置</text>
                <text class="setting-desc">配置活动封面的默认 Banner 图片。</text>
              </view>
              <view class="setting-arrow">
                <text>→</text>
              </view>
            </view>

            <!-- 缓存日志清理入口 -->
            <view class="setting-item clickable" bindtap="goToCacheCleanup">
              <view class="setting-icon orange">
                <text>🗑️</text>
              </view>
              <view class="setting-info">
                <text class="setting-title">缓存日志清理</text>
                <text class="setting-desc">清理系统日志、通知记录、临时文件等缓存数据。</text>
              </view>
              <view class="setting-arrow">
                <text>→</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 系统通知 -->
    <view class="notice-card">
      <view class="notice-icon">
        <text>⚠️</text>
      </view>
      <view class="notice-content">
        <text class="notice-title">系统通知</text>
        <text class="notice-desc">请定期检查待审核用户，确保新用户能够及时参与活动。当前有 <text class="notice-highlight">{{pendingUsers.length}}</text> 位用户等待审核。</text>
      </view>
    </view>
    
    <!-- 底部安全区域 -->
    <view class="bottom-safe-area"></view>
  </scroll-view>
</view>
