/**
 * 活动详情页样式
 * 与网页版 TournamentDetail.tsx 样式完全一致
 */

.page {
  min-height: 100vh;
  background-color: #f9fafb;
  display: flex;
  flex-direction: column;
}

.page.dark {
  background-color: #111827;
}

/* 顶部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 30;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.dark .header {
  background-color: #1f2937;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 40rpx;
  color: #1f2937;
}

.dark .back-btn {
  color: #ffffff;
}

.back-btn:active {
  background-color: #f3f4f6;
}

.dark .back-btn:active {
  background-color: #374151;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .header-title {
  color: #ffffff;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.theme-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.theme-btn text {
  font-size: 40rpx;
}

/* 加载状态 */
.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e5e7eb;
  border-top-color: #ef4444;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding-bottom: 160rpx;
}

/* 通用卡片样式 */
.card {
  margin: 32rpx 24rpx;
  padding: 40rpx 36rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #f3f4f6;
}

.dark .card {
  background-color: #1f2937;
  border-color: #374151;
}

/* 提示卡片 */
.tip-card {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
  margin: 24rpx 24rpx 0;
  border-radius: 24rpx;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tip-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
}

/* 蓝色提示 - 信息 */
.tip-card.blue {
  background-color: #eff6ff;
}

.dark .tip-card.blue {
  background-color: rgba(59, 130, 246, 0.15);
}

.tip-card.blue .tip-title {
  color: #2563eb;
}

.dark .tip-card.blue .tip-title {
  color: #93c5fd;
}

.tip-card.blue .tip-desc {
  color: #3b82f6;
}

.dark .tip-card.blue .tip-desc {
  color: #93c5fd;
}

/* 绿色提示 - 成功 */
.tip-card.green {
  background-color: #f0fdf4;
}

.dark .tip-card.green {
  background-color: rgba(34, 197, 94, 0.15);
}

.tip-card.green .tip-title {
  color: #16a34a;
}

.dark .tip-card.green .tip-title {
  color: #86efac;
}

.tip-card.green .tip-desc {
  color: #22c55e;
}

.dark .tip-card.green .tip-desc {
  color: #86efac;
}

/* 橙色提示 - 警告 */
.tip-card.orange {
  background-color: #fff7ed;
}

.dark .tip-card.orange {
  background-color: rgba(249, 115, 22, 0.15);
}

.tip-card.orange .tip-title {
  color: #ea580c;
}

.dark .tip-card.orange .tip-title {
  color: #fdba74;
}

.tip-card.orange .tip-desc {
  color: #f97316;
}

.dark .tip-card.orange .tip-desc {
  color: #fdba74;
}

/* 灰色提示 - 普通 */
.tip-card.gray {
  background-color: #f3f4f6;
}

.dark .tip-card.gray {
  background-color: rgba(107, 114, 128, 0.15);
}

.tip-card.gray .tip-title {
  color: #4b5563;
}

.dark .tip-card.gray .tip-title {
  color: #d1d5db;
}

.tip-card.gray .tip-desc {
  color: #6b7280;
}

.dark .tip-card.gray .tip-desc {
  color: #9ca3af;
}

/* 红色提示卡 - 完全锁定警告 */
.tip-card.red {
  background-color: #fee2e2;
}

.dark .tip-card.red {
  background-color: rgba(220, 38, 38, 0.15);
}

.tip-card.red .tip-title {
  color: #991b1b;
}

.dark .tip-card.red .tip-title {
  color: #fca5a5;
}

.tip-card.red .tip-desc {
  color: #b91c1c;
}

.dark .tip-card.red .tip-desc {
  color: #f87171;
}

/* Banner图片 - 16:3 宽高比 + 深色边框遮罩 */
.banner-section {
  position: relative;
  width: calc(100% - 48rpx);
  margin: 24rpx;
  /* 16:3 比例 = 3/16 = 18.75% */
  padding-top: 18.75%;
  overflow: hidden;
  border-radius: 16rpx;
  border: 0rpx solid #1f2937;
  box-sizing: border-box;
}

.dark .banner-section {
  border-color: #374151;
}

.banner-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.status-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 700;
  opacity: 0.9;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 状态颜色 */
.status-pre-registration {
  background-color: #dbeafe;
  color: #1e40af;
}

.status-registration {
  background-color: #dcfce7;
  color: #166534;
  animation: detail-status-pulse 2s infinite ease-in-out;
}

@keyframes detail-status-pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.status-waiting-list {
  background-color: #fef9c3;
  color: #854d0e;
}

.status-full {
  background-color: #f3f4f6;
  color: #1f2937;
}

.status-finished-pending {
  background-color: #ffedd5;
  color: #9a3412;
}

.status-finished-completed {
  background-color: #e0e7ff;
  color: #3730a3;
}

.status-cancelled {
  background-color: #fee2e2;
  color: #991b1b;
}

/* 标题区域 */
.title-section {
  padding: 32rpx;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.tournament-title {
  flex: 1;
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.3;
}

.dark .tournament-title {
  color: #ffffff;
}

.share-btn {
  padding: 12rpx 24rpx;
  background-color: #f3f4f6;
  border-radius: 9999rpx;
  font-size: 28rpx;
  color: #4b5563;
  white-space: nowrap;
}

.dark .share-btn {
  background-color: #374151;
  color: #9ca3af;
}

.meta-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #6b7280;
}

.dark .meta-item {
  color: #9ca3af;
}

.meta-icon {
  margin-right: 12rpx;
}

/* 区域标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .section-title {
  color: #ffffff;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.count-badge {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background-color: #f3f4f6;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
}

.dark .count-badge {
  background-color: #374151;
  color: #9ca3af;
}

.add-btn {
  padding: 12rpx 24rpx;
  background-color: #ef4444;
  color: #ffffff;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 费用结算 */
.cost-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.cost-item {
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  text-align: center;
}

.dark .cost-item {
  background-color: rgba(55, 65, 81, 0.5);
}

.cost-item.highlight {
  background-color: #fef2f2;
  border: 2rpx solid #fca5a5;
}

.dark .cost-item.highlight {
  background-color: rgba(127, 29, 29, 0.2);
  border-color: #991b1b;
}

.cost-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.dark .cost-label {
  color: #9ca3af;
}

.cost-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .cost-value {
  color: #ffffff;
}

.cost-item.highlight .cost-value {
  color: #ef4444;
}

/* 参与者网格 */
.participants-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.participant-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  position: relative;
}

.dark .participant-item {
  background-color: rgba(55, 65, 81, 0.5);
}

.participant-item.is-me {
  background-color: #fef2f2;
  border: 2rpx solid #fca5a5;
}

.dark .participant-item.is-me {
  background-color: rgba(127, 29, 29, 0.2);
  border-color: #991b1b;
}

.participant-item.is-owner {
  cursor: pointer;
}

.participant-avatar {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.participant-avatar image {
  width: 100%;
  height: 100%;
}

.me-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background-color: #ef4444;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
}

.participant-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
  text-align: center;
}

.dark .participant-name {
  color: #ffffff;
}

.proxy-label {
  font-size: 22rpx;
  color: #ef4444;
  margin-top: 4rpx;
}

.score-input-wrapper {
  margin-top: 12rpx;
  width: 100%;
}

.score-input {
  width: 100%;
  padding: 12rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  box-sizing: border-box;
}

.dark .score-input {
  background-color: #374151;
  border-color: #4b5563;
  color: #ffffff;
}

.score-display {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.dark .score-display {
  color: #9ca3af;
}

.empty-participants {
  grid-column: 1 / -1;
  text-align: center;
  padding: 48rpx;
  color: #6b7280;
}

.dark .empty-participants {
  color: #9ca3af;
}

/* 积分操作按钮 */
.score-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f3f4f6;
}

/* 补充图片 */
.description-images {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.desc-image {
  width: 100%;
  border-radius: 16rpx;
}

.dark .score-actions {
  border-top-color: #374151;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.info-item {
  padding: 16rpx;
  background-color: #f9fafb;
  border-radius: 12rpx;
}

.dark .info-item {
  background-color: rgba(55, 65, 81, 0.5);
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

.dark .info-label {
  color: #9ca3af;
}

.info-value {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
}

.dark .info-value {
  color: #ffffff;
}

/* 描述和规则 */
.description-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #4b5563;
}

.dark .description-text {
  color: #9ca3af;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
}

.rule-number {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ef4444;
  color: #ffffff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.rule-text {
  flex: 1;
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.6;
}

.dark .rule-text {
  color: #9ca3af;
}

/* 底部操作区 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 24rpx 24rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: transparent;
  z-index: 20;
}

.dark .footer-actions {
  background-color: transparent;
}

.enroll-btn {
  flex: 1;
  width: calc(100vw - 48rpx);
  min-width: 600rpx;
  padding: 32rpx 24rpx;
  background: linear-gradient(to right, #ef4444, #fb923c);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  white-space: nowrap;
  text-align: center;
  box-sizing: border-box;
}

.enroll-btn::after {
  border: none;
}

.enroll-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.dark .enroll-btn.disabled {
  background: #374151;
  color: #6b7280;
}

/* 通用按钮 */
.btn-primary {
  flex: 1;
  padding: 20rpx 32rpx;
  background: linear-gradient(to right, #ef4444, #fb923c);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  flex: 1;
  padding: 20rpx 32rpx;
  background-color: #f3f4f6;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.dark .btn-secondary {
  background-color: #374151;
  color: #ffffff;
}

.btn-secondary::after {
  border: none;
}

.btn-ghost {
  flex: 1;
  padding: 20rpx 32rpx;
  background-color: transparent;
  color: #6b7280;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.btn-ghost::after {
  border: none;
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal {
  width: 100%;
  max-width: 640rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.dark .modal {
  background-color: #1f2937;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dark .modal-header {
  border-bottom-color: #374151;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .modal-title {
  color: #ffffff;
}

.modal-close {
  font-size: 56rpx;
  color: #6b7280;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #f3f4f6;
  display: flex;
  gap: 24rpx;
}

.dark .modal-footer {
  border-top-color: #374151;
}

/* 报名选项 */
.enroll-options {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.enroll-option {
  flex: 1;
  padding: 32rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.dark .enroll-option {
  background-color: rgba(55, 65, 81, 0.5);
}

.enroll-option.active {
  border-color: #ef4444;
  background-color: #fef2f2;
}

.dark .enroll-option.active {
  background-color: rgba(127, 29, 29, 0.2);
}

.enroll-option.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.enrolled-hint {
  font-size: 22rpx;
  color: #9ca3af;
}

.option-icon {
  font-size: 48rpx;
}

.enroll-option text:last-child {
  font-size: 28rpx;
  color: #1f2937;
}

.dark .enroll-option text:last-child {
  color: #ffffff;
}

.enroll-name-input {
  margin-top: 24rpx;
  margin-bottom: 16rpx;
}

.enroll-name-label {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #374151;
}

.dark .enroll-name-label {
  color: #d1d5db;
}

.enroll-name-label .label-hint {
  font-size: 24rpx;
  color: #ef4444;
}

.dark .enroll-name-label .label-hint {
  color: #fbbf24;
}

.enroll-input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  color: #1f2937;
}

.dark .enroll-input-field {
  background-color: #374151;
  border-color: #4b5563;
  color: #ffffff;
}

.input-placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

.dark .input-placeholder {
  color: #6b7280;
}

/* 表单项 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.dark .form-label {
  color: #ffffff;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.dark .form-input {
  background-color: #374151;
  border-color: #4b5563;
  color: #ffffff;
}

.type-options {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background-color: #f3f4f6;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #4b5563;
  border: 2rpx solid transparent;
}

.dark .type-option {
  background-color: #374151;
  color: #9ca3af;
}

.type-option.active {
  background-color: #fef2f2;
  border-color: #ef4444;
  color: #ef4444;
}

.dark .type-option.active {
  background-color: rgba(127, 29, 29, 0.2);
}

/* 分享模态框 */
.share-modal {
  max-width: 560rpx;
}

.share-preview {
  background-color: #f9fafb;
  border-radius: 16rpx;
  overflow: hidden;
}

