/* 下载按钮 - 与订阅按钮风格一致 */
.download-btn {
  display: inline-flex !important;
  align-items: center;
  padding: 8rpx 20rpx !important;
  background-color: transparent !important;
  border: 2rpx solid #3b82f6 !important;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #3b82f6;
  line-height: 1.5;
  width: auto !important;
  min-height: auto !important;
}

.download-btn::after {
  border: none;
}

.dark .download-btn {
  border-color: #60a5fa !important;
  color: #60a5fa;
}

/* ==================== 独立积分录入卡片 ==================== */
.score-section {
  margin-top: 24rpx;
}

.score-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f3f4f6;
  margin-bottom: 16rpx;
}

.dark .score-section-header {
  border-bottom-color: #374151;
}

.score-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.dark .score-section-title {
  color: #ffffff;
}

.score-edit-btn {
  padding: 12rpx 24rpx;
  background-color: #ef4444;
  border-radius: 20rpx;
  color: #ffffff;
  font-size: 26rpx;
}

.score-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.score-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f9fafb;
  border-radius: 16rpx;
}

.dark .score-item {
  background-color: #374151;
}

.score-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.score-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #e5e7eb;
}

.score-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
}

.dark .score-name {
  color: #ffffff;
}

.score-item-right {
  display: flex;
  align-items: center;
}

.score-input-box {
  width: 120rpx;
  height: 64rpx;
  padding: 0 16rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  background-color: #ffffff;
}

.dark .score-input-box {
  background-color: #1f2937;
  border-color: #4b5563;
  color: #ffffff;
}

.score-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #ef4444;
  min-width: 100rpx;
  text-align: right;
}

.score-actions-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f3f4f6;
}

.dark .score-actions-row {
  border-top-color: #374151;
}

.score-btn-quick,
.score-btn-save,
.score-btn-cancel {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  padding: 0;
  margin: 0;
}

.score-btn-quick {
  background-color: #fef3c7 !important;
  color: #92400e !important;
  border: none;
}

.score-btn-save {
  background: linear-gradient(135deg, #f97316, #ef4444) !important;
  color: #ffffff !important;
  border: none;
}

.score-btn-cancel {
  background-color: #f3f4f6 !important;
  color: #6b7280 !important;
  border: none;
}

.dark .score-btn-cancel {
  background-color: #4b5563 !important;
  color: #d1d5db !important;
}

/* 锁定按钮和操作区域 */
/* 管理员操作按钮行 - 在标题上方 */
.admin-actions-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.section-header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.lock-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  background-color: #f3f4f6;
  color: #6b7280;
  transition: all 0.2s ease;
}

.dark .lock-btn {
  background-color: #374151;
  color: #9ca3af;
}

/* 基本锁定 (lockState === 1) - 橙色 */
.lock-btn.basic-locked {
  background-color: #fef3c7;
  color: #92400e;
}

.dark .lock-btn.basic-locked {
  background-color: rgba(234, 88, 12, 0.2);
  color: #fb923c;
}

/* 完全锁定 (lockState === 2) - 红色 */
.lock-btn.fully-locked {
  background-color: #fee2e2;
  color: #991b1b;
}

.dark .lock-btn.fully-locked {
  background-color: rgba(220, 38, 38, 0.2);
  color: #f87171;
}

.lock-icon {
  font-size: 28rpx;
}

/* 开始提醒按钮 */
.start-reminder-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  background-color: #dbeafe;
  color: #1e40af;
  transition: all 0.2s ease;
}

.dark .start-reminder-btn {
  background-color: rgba(59, 130, 246, 0.2);
  color: #60a5fa;
}

.reminder-icon {
  font-size: 28rpx;
}

/* 提示文字样式 - 红色(light)/金色(dark) */
.label-hint {
  color: #ef4444;
  font-size: 24rpx;
}

.dark .label-hint {
  color: #fbbf24;
}
